# agenda.env — segredos do módulo de agenda (copie para agenda.env e preencha; chmod 600)
# URL iCal privada do Google Calendar (Configurações da agenda > Integrar agenda > Endereço secreto no formato iCal).
# É um SEGREDO: quem tiver a URL lê sua agenda inteira.
AGENDA_ICAL_DCX=https://calendar.google.com/calendar/ical/SEU_EMAIL/private-SEU_TOKEN/basic.ics
