[Unit]
Description=PIrrai email watcher (1 ciclo)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=rodrigor
Group=rodrigor
Environment=HOME=/home/rodrigor
WorkingDirectory=/home/rodrigor/homewatch
ExecStart=/usr/bin/python3 /home/rodrigor/homewatch/email_watch.py
