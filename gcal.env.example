# gcal.env — credenciais OAuth do Google Calendar (copie p/ gcal.env e preencha; chmod 600)
# Crie em https://console.cloud.google.com → APIs & Services → Credentials → OAuth client ID (Desktop app)
GCAL_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GCAL_CLIENT_SECRET=GOCSPX-xxxxxxxx
# Calendário a manipular: o e-mail da agenda, ou 'primary' (a principal da conta autorizada)
GCAL_CALENDAR_ID=rodrigor@dcx.ufpb.br
