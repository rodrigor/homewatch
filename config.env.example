# homewatch — configuração (copie para config.env e preencha os valores)
# NÃO commite config.env — ele contém segredos.

# ── Telegram ──────────────────────────────────────────────────────────
# Crie um bot no @BotFather e cole o token aqui.
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Seu chat_id pessoal (admin). Rode get_chat_id.sh para descobrir.
TELEGRAM_CHAT_ID=1234567890

# ── Claude AI ─────────────────────────────────────────────────────────
# Modelo padrão: sonnet, opus ou haiku
CLAUDE_MODEL=sonnet
